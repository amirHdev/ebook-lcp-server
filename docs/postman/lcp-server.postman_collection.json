{
  "info": {
    "name": "LCP Server",
    "_postman_id": "ad0e0f4f-0ba7-4fb1-aef3-4db15b6327ef",
    "description": "Common local API requests for the LCP server.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "publicationId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\",\n  \"twoFactor\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Status",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/lcp/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "lcp",
            "status"
          ]
        }
      }
    },
    {
      "name": "List publications",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/publications",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "publications"
          ]
        }
      }
    },
    {
      "name": "Create publication",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Example publication\",\n  \"encrypted_uri\": \"https://example.test/publications/example/content\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/publications",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "publications"
          ]
        }
      }
    },
    {
      "name": "Admin metrics",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "X-2FA-Code",
            "value": "123456"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/metrics",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "metrics"
          ]
        }
      }
    }
  ]
}
